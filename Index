async function startBankQuiz() {
  S.mode = 'bank';
  const all = await txGetAll('questions');
  let pool = all.filter(q => S.types.has(q.type) && S.diffs.has(q.difficulty));
  if (!pool.length) { alert('沒有符合條件的題目！請調整篩選。'); return; }
  pool = pool.sort(() => Math.random() - .5);
  S.quiz = pool.slice(0, Math.min(S.num, pool.length));
  S.cur = 0; S.answers = []; S.sel = null; S.elapsed = 0; S.submitted = false;
  showScreen('qScreen');
  startTimer();
  renderQ();
}

