<script>
/* ════════════════════════════════════════════════
   IndexedDB — 資料庫層
   DB名稱: GmatPracticeDB
   版本: 1
   Object Stores:
     questions  — 題庫（可存數萬題）
     history    — 每次答題記錄（可存數十萬筆）
     wronglog   — 錯題（自動去重）
     settings   — 設定（API key等）
════════════════════════════════════════════════ */
const DB_NAME = 'GmatPracticeDB';
const DB_VER  = 1;
let db = null;

function initDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(DB_NAME, DB_VER);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains('questions')) {
        const qs = d.createObjectStore('questions', { keyPath: 'id' });
        qs.createIndex('type', 'type');
        qs.createIndex('difficulty', 'difficulty');
        qs.createIndex('typeAndDiff', ['type','difficulty']);
      }
      if (!d.objectStoreNames.contains('history')) {
        const hs = d.createObjectStore('history', { keyPath: 'id', autoIncrement: true });
        hs.createIndex('timestamp', 'timestamp');
        hs.createIndex('type', 'type');
        hs.createIndex('difficulty', 'difficulty');
      }
      if (!d.objectStoreNames.contains('wronglog')) {
        d.createObjectStore('wronglog', { keyPath: 'qid' });
      }
      if (!d.objectStoreNames.contains('settings')) {
        d.createObjectStore('settings', { keyPath: 'key' });
      }
    };
    req.onsuccess = e => { db = e.target.result; resolve(db); };
    req.onerror   = e => reject(e.target.error);
  });
}

// Generic DB helpers
function txGet(store, key) {
  return new Promise((res, rej) => {
    const req = db.transaction(store,'readonly').objectStore(store).get(key);
    req.onsuccess = e => res(e.target.result);
    req.onerror   = e => rej(e.target.error);
  });
}
function txPut(store, val) {
  return new Promise((res, rej) => {
    const req = db.transaction(store,'readwrite').objectStore(store).put(val);
    req.onsuccess = e => res(e.target.result);
    req.onerror   = e => rej(e.target.error);
  });
}
function txDelete(store, key) {
  return new Promise((res, rej) => {
    const req = db.transaction(store,'readwrite').objectStore(store).delete(key);
    req.onsuccess = e => res();
    req.onerror   = e => rej(e.target.error);
  });
}
function txCount(store) {
  return new Promise((res, rej) => {
    const req = db.transaction(store,'readonly').objectStore(store).count();
    req.onsuccess = e => res(e.target.result);
    req.onerror   = e => rej(e.target.error);
  });
}
function txGetAll(store) {
  return new Promise((res, rej) => {
    const req = db.transaction(store,'readonly').objectStore(store).getAll();
    req.onsuccess = e => res(e.target.result);
    req.onerror   = e => rej(e.target.error);
  });
}
function txClear(store) {
  return new Promise((res, rej) => {
    const req = db.transaction(store,'readwrite').objectStore(store).clear();
    req.onsuccess = () => res();
    req.onerror   = e => rej(e.target.error);
  });
}
function txGetByIndex(store, indexName, value) {
  return new Promise((res, rej) => {
    const tx = db.transaction(store,'readonly');
    const req = tx.objectStore(store).index(indexName).getAll(value);
    req.onsuccess = e => res(e.target.result);
    req.onerror   = e => rej(e.target.error);
  });
}
function txPutBulk(store, items) {
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readwrite');
    const os = tx.objectStore(store);
    items.forEach(item => os.put(item));
    tx.oncomplete = () => res();
    tx.onerror    = e => rej(e.target.error);
  });
}

/* ════════════════════════════════════════════════
   QUESTION GENERATORS — 產生 500+ 題
════════════════════════════════════════════════ */
function rn(a,b){return Math.floor(Math.random()*(b-a+1))+a}
function shuffle(arr){return [...arr].sort(()=>Math.random()-.5)}
function L(i){return String.fromCharCode(65+i)}
function lcm(a,b){return a*b/gcd(a,b)}
function gcd(a,b){return b?gcd(b,a%b):a}
function uid(){return 'Q'+Date.now().toString(36)+Math.random().toString(36).slice(2,6)}

const GENERATORS = [
  // ── QUANTITATIVE · Problem Solving · Easy ──────────────────
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const a=rn(2,5),b=rn(1,8),x=rn(1,9),c=a*x+b,ans=x+1;
    const opts=shuffle([ans,ans+1,ans-1,ans+2,ans+3]).slice(0,5);
    const ai=opts.findIndex(v=>v===ans);
    return{q:`If <strong>${a}x + ${b} = ${c}</strong>, what is <strong>x + 1</strong>?`,o:opts.map(String),a:ai,ex:`${a}x = ${c-b} → x = ${x}。x + 1 = <strong>${ans}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const p=rn(2,8)*10,disc=[10,20,25,30,40][rn(0,4)],sale=p*(100-disc)/100;
    const opts=shuffle([sale,sale+5,sale-5,sale+10,p]).filter(v=>v>0).slice(0,5);
    const ai=opts.findIndex(v=>v===sale);
    return{q:`A jacket originally costs $${p} and is <strong>${disc}% off</strong>. What is the sale price?`,o:opts.map(v=>'$'+v),a:ai,ex:`折扣 = $${p} × ${disc}% = $${p*disc/100}。售價 = $${p} − $${p*disc/100} = <strong>$${sale}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const n=rn(3,6),avg=rn(10,18),sum=n*avg;
    const given=Array.from({length:n-1},()=>rn(avg-4,avg+4));
    const last=sum-given.reduce((a,b)=>a+b,0);
    const opts=shuffle([last,last+1,last-1,last+2,last-2]).slice(0,5);
    const ai=opts.findIndex(v=>v===last);
    return{q:`The average of ${n} numbers is ${avg}. ${n-1} of them are ${given.join(', ')}. What is the last number?`,o:opts.map(String),a:ai,ex:`總和 = ${avg}×${n} = ${sum}。已知和 = ${given.reduce((a,b)=>a+b,0)}。最後一個 = ${sum} − ${given.reduce((a,b)=>a+b,0)} = <strong>${last}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const base=rn(2,9)*rn(2,9),pct=[10,20,25,30,40,50][rn(0,5)],val=base*pct/100;
    const opts=shuffle([val,val+5,val-5,val*2,base-val]).filter(v=>v>=0).slice(0,5);
    const ai=opts.findIndex(v=>v===val);
    return{q:`What is <strong>${pct}%</strong> of <strong>${base}</strong>?`,o:opts.map(String),a:ai,ex:`${pct}% × ${base} = ${pct/100} × ${base} = <strong>${val}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const l=rn(5,15),w=rn(3,9),area=l*w,perim=2*(l+w);
    const opts=shuffle([area,perim,l*l,w*w,area+l]).slice(0,5);
    const ai=opts.findIndex(v=>v===area);
    return{q:`A rectangle has length <strong>${l}</strong> and width <strong>${w}</strong>. What is its <strong>area</strong>?`,o:opts.map(String),a:ai,ex:`面積 = 長 × 寬 = ${l} × ${w} = <strong>${area}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const l=rn(5,15),w=rn(3,9),area=l*w,perim=2*(l+w);
    const opts=shuffle([perim,area,2*l+w,l+2*w,perim+2]).slice(0,5);
    const ai=opts.findIndex(v=>v===perim);
    return{q:`A rectangle has length <strong>${l}</strong> and width <strong>${w}</strong>. What is its <strong>perimeter</strong>?`,o:opts.map(String),a:ai,ex:`周長 = 2×(長+寬) = 2×(${l}+${w}) = 2×${l+w} = <strong>${perim}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const spd=rn(4,9)*10,hrs=rn(1,5),dist=spd*hrs;
    const opts=shuffle([dist,dist+spd,dist-spd,spd+hrs,dist*2]).filter(v=>v>0).slice(0,5);
    const ai=opts.findIndex(v=>v===dist);
    return{q:`A car travels at <strong>${spd} mph</strong> for <strong>${hrs} hours</strong>. How far does it travel?`,o:opts.map(v=>v+' miles'),a:ai,ex:`距離 = 速度 × 時間 = ${spd} × ${hrs} = <strong>${dist} miles</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const a=rn(2,6),b=rn(2,5),ans=a**3-b**2;
    const opts=shuffle([ans,ans+2,ans-2,a**2-b**3,a**2+b**2]).slice(0,5);
    const ai=opts.findIndex(v=>v===ans);
    return{q:`What is <strong>${a}³ − ${b}²</strong>?`,o:opts.map(String),a:ai,ex:`${a}³ = ${a**3}，${b}² = ${b**2}。${a**3} − ${b**2} = <strong>${ans}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const a=rn(10,99),b=rn(10,99),ans=a+b;
    const pct=rn(2,8)*10,tot=rn(100,300),part=Math.round(tot*pct/100);
    const opts=shuffle([part,part+10,part-10,tot-part,Math.round(tot/pct)]).filter(v=>v>0).slice(0,5);
    const ai=opts.findIndex(v=>v===part);
    return{q:`In a school of <strong>${tot}</strong> students, <strong>${pct}%</strong> are in the science program. How many students are in the science program?`,o:opts.map(String),a:ai,ex:`${tot} × ${pct}% = ${tot} × ${pct/100} = <strong>${part}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Easy',sub:'Problem Solving', gen:()=>{
    const coins=[1,5,10,25],coin=coins[rn(0,3)];
    const n=rn(4,20),total=n*coin;
    const opts=shuffle([total,total+coin,total-coin,total*2,n]).filter(v=>v>0).slice(0,5);
    const ai=opts.findIndex(v=>v===total);
    const names={1:'pennies',5:'nickels',10:'dimes',25:'quarters'};
    return{q:`You have <strong>${n} ${names[coin]}</strong>. How many cents do you have in total?`,o:opts.map(v=>v+' cents'),a:ai,ex:`${n} × ${coin} cents = <strong>${total} cents</strong>。答案為 (${L(ai)})。`};
  }},

  // ── QUANTITATIVE · Problem Solving · Medium ─────────────────
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const d1=rn(60,150),t1=rn(1,3),d2=rn(80,200),t2=rn(2,4);
    const avg=Math.round((d1+d2)/(t1+t2)*10)/10;
    const opts=shuffle([avg,Math.round(d1/t1),Math.round(d2/t2),Math.round((d1/t1+d2/t2)/2*10)/10,avg+5]).slice(0,5);
    const ai=opts.findIndex(v=>v===avg);
    return{q:`A car travels ${d1} miles in ${t1} hr${t1>1?'s':''}, then ${d2} miles in ${t2} hrs. What is the <strong>average speed</strong> for the whole trip?`,o:opts.map(v=>v+' mph'),a:ai,ex:`平均速度 = 總距離/總時間 = (${d1}+${d2})/(${t1}+${t2}) = ${d1+d2}/${t1+t2} ≈ <strong>${avg} mph</strong>。注意：不能直接平均兩段速度。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const tot=rn(25,60),a=rn(12,tot-5),b=rn(12,tot-5),neither=rn(2,6);
    const both=Math.max(0,a+b-(tot-neither));
    const opts=shuffle([both,both+1,both-1,neither,both+2]).filter(v=>v>=0).slice(0,5);
    const ai=opts.findIndex(v=>v===both);
    return{q:`In a group of ${tot}, ${a} like soccer and ${b} like basketball. If ${neither} like <strong>neither</strong>, how many like <strong>both</strong>?`,o:opts.map(String),a:ai,ex:`至少一種 = ${tot}−${neither} = ${tot-neither}。包含排除：${a}+${b}−both = ${tot-neither} → both = <strong>${both}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const principal=rn(5,20)*100,rate=rn(2,8),years=rn(2,5);
    const si=principal*rate*years/100;
    const opts=shuffle([si,si+principal*rate/100,si*2,principal*rate/100,si-principal]).filter(v=>v>0).slice(0,5);
    const ai=opts.findIndex(v=>v===si);
    return{q:`What is the <strong>simple interest</strong> on $${principal} at <strong>${rate}%</strong> per year for <strong>${years} years</strong>?`,o:opts.map(v=>'$'+v),a:ai,ex:`單利 = 本金 × 利率 × 年數 = ${principal} × ${rate/100} × ${years} = <strong>$${si}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const w=rn(4,9),extra=rn(2,6),l=2*w+extra,area=l*w,perim=2*(l+w);
    const opts=shuffle([area,perim,l*l,w*w,l+w]).slice(0,5);
    const ai=opts.findIndex(v=>v===area);
    return{q:`A rectangle's length is <strong>${extra} more than twice</strong> its width. If the width is <strong>${w}</strong>, what is the area?`,o:opts.map(v=>v+' sq units'),a:ai,ex:`長 = 2×${w}+${extra} = ${l}。面積 = ${l}×${w} = <strong>${area} sq units</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const r1=rn(2,5),r2=rn(3,7),lcmVal=lcm(r1,r2);
    const opts=shuffle([lcmVal,lcmVal+r1,lcmVal-r2,r1*r2,lcmVal*2]).slice(0,5);
    const ai=opts.findIndex(v=>v===lcmVal);
    return{q:`Machine A produces a widget every <strong>${r1} minutes</strong>, Machine B every <strong>${r2} minutes</strong>. Starting together, after how many minutes do they <strong>both finish simultaneously</strong>?`,o:opts.map(v=>v+' min'),a:ai,ex:`求最小公倍數。LCM(${r1},${r2}) = <strong>${lcmVal} 分鐘</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const tot=rn(100,400),pA=rn(30,55),a=Math.round(tot*pA/100),b=tot-a;
    const opts=shuffle([b,a,tot,Math.round(tot/2),Math.round(tot*.3)]).slice(0,5);
    const ai=opts.findIndex(v=>v===b);
    return{q:`In a company of <strong>${tot}</strong> employees, <strong>${pA}%</strong> are in department A. How many are <strong>NOT</strong> in department A?`,o:opts.map(String),a:ai,ex:`部門A = ${tot}×${pA}% = ${a}人。非A = ${tot}−${a} = <strong>${b}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const markup=rn(20,60),cost=rn(50,200),sell=cost*(100+markup)/100;
    const opts=shuffle([sell,sell+cost*0.1,sell-cost*0.1,cost,sell*1.1]).slice(0,5);
    const ai=opts.findIndex(v=>v===sell);
    return{q:`A store buys an item for $${cost} and marks it up <strong>${markup}%</strong>. What is the selling price?`,o:opts.map(v=>'$'+v),a:ai,ex:`售價 = $${cost} × (1+${markup}%) = $${cost} × ${(100+markup)/100} = <strong>$${sell}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Medium',sub:'Problem Solving', gen:()=>{
    const a=rn(2,8),b=rn(2,8);
    const ans=a**2+b**2;
    const opts=shuffle([ans,ans+2,ans-2,(a+b)**2,a*b]).slice(0,5);
    const ai=opts.findIndex(v=>v===ans);
    return{q:`What is the value of <strong>${a}² + ${b}²</strong>?`,o:opts.map(String),a:ai,ex:`${a}² = ${a**2}，${b}² = ${b**2}。合計 = <strong>${ans}</strong>。注意：(${a}+${b})² = ${(a+b)**2} ≠ ${ans}。答案為 (${L(ai)})。`};
  }},

  // ── QUANTITATIVE · Problem Solving · Hard ───────────────────
  {type:'Q',difficulty:'Hard',sub:'Problem Solving', gen:()=>{
    const fill=rn(4,10),drain=fill+rn(2,8);
    const net=(drain-fill)/(fill*drain);
    const hrs=Math.round(1/net*10)/10;
    const opts=shuffle([hrs,hrs+2,hrs-2,fill,drain]).slice(0,5);
    const ai=opts.findIndex(v=>v===hrs);
    return{q:`Pump A fills a tank in <strong>${fill} hrs</strong>. Pump B drains it in <strong>${drain} hrs</strong>. Starting full, how long until the tank is <strong>empty</strong>?`,o:opts.map(v=>v+' hrs'),a:ai,ex:`每小時淨排空率 = 1/${drain} − 1/${fill} = ${fill-drain}/${fill*drain}（排空為正）。清空需 ${fill*drain}/${drain-fill} ≈ <strong>${hrs} hrs</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Hard',sub:'Problem Solving', gen:()=>{
    const n=rn(50,200),d3=Math.floor(n/3),d5=Math.floor(n/5),d15=Math.floor(n/15);
    const ans=(d3-d15)+(d5-d15);
    const opts=shuffle([ans,d3+d5,d3,d5,ans+d15]).slice(0,5);
    const ai=opts.findIndex(v=>v===ans);
    return{q:`How many integers from 1 to ${n} are divisible by 3 <strong>or</strong> 5 but <strong>NOT both</strong>?`,o:opts.map(String),a:ai,ex:`被3整除：${d3}個；被5整除：${d5}個；被15整除（兩者）：${d15}個。只被3：${d3-d15}；只被5：${d5-d15}。合計 = <strong>${ans}</strong>。答案為 (${L(ai)})。`};
  }},
  {type:'Q',difficulty:'Hard',sub:'Problem Solving', gen:()=>{
