  else { ring.style.borderColor='var(--red)'; pEl.style.color='var(--red)'; document.getElementById('scoreMsg').textContent='Keep Studying! 📚'; document.getElementById('scoreSub').textContent='複習錯題詳解，打好基礎！'; }
  document.getElementById('rC').textContent = ok;
  document.getElementById('rW').textContent = tot-ok;
  document.getElementById('rT').textContent = fmt(S.elapsed);
  const tN={Q:'Quantitative',V:'Verbal',D:'Data Insights'};
  document.getElementById('reviewEl').innerHTML = S.answers.map((a,i)=>
    `<div class="review-item ${a.ok?'ri-ok':'ri-no'}">
       <div class="ri-meta">Q${i+1} · ${a.q.subtype} · ${a.q.difficulty}${a.q.source==='ai'?' · 🤖':''}</div>
       <div class="ri-text">${(a.q.question||'').replace(/<[^>]+>/g,'').slice(0,100)}…</div>
       <div class="ri-bottom">
         ${a.ok?'<span style="color:var(--green);font-size:.78rem">✅ 正確</span>':'<span style="color:var(--red);font-size:.78rem">❌ 錯誤</span>'}
         <span class="badge badge-${a.q.difficulty}" style="font-size:.56rem">${a.q.difficulty}</span>
         <span style="font-family:'DM Mono',monospace;font-size:.68rem;color:var(--muted)">你:${L(a.chosen)} · 答:${L(a.q.answer)}</span>
       </div>
     </div>`).join('');
}

/* ════════════════════════════════════════════════
   TIMER & UTILS
════════════════════════════════════════════════ */
function startTimer() {
  const el = document.getElementById('timerEl');
  el.style.display=''; el.className=''; S.elapsed=0;
  S.tick = setInterval(()=>{
    S.elapsed++;
    el.textContent = fmt(S.elapsed);
    const avg = S.elapsed/(S.cur+1);
    el.className = avg>180?'danger':avg>120?'warn':'';
  },1000);
}
function stopTimer(){ clearInterval(S.tick); }
function fmt(s){ return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`; }
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}
async function goHome(){
  stopTimer();
  document.getElementById('timerEl').style.display='none';
  showScreen('homeScreen');
  await refreshHeader();
}

/* ════════════════════════════════════════════════
   INIT
════════════════════════════════════════════════ */
async function init() {
  try {
    document.getElementById('initMsg').textContent = '開啟 IndexedDB...';
    document.getElementById('initBar').style.width = '10%';
    await initDB();

    document.getElementById('initMsg').textContent = '檢查題庫...';
    document.getElementById('initBar').style.width = '20%';
    const count = await txCount('questions');

    if (count < 100) {
      document.getElementById('initMsg').textContent = '首次啟動，生成題庫...';
      await generateAndStore((done, total) => {
        document.getElementById('initMsg').textContent = `生成題庫 ${done}/${total}...`;
        document.getElementById('initBar').style.width = Math.round(20+done/total*70)+'%';
      });
    }

    document.getElementById('initBar').style.width = '95%';
    // Load saved API key
    const savedKey = await getSetting('apiKey');
    if (savedKey) document.getElementById('apiKeyInput').value = savedKey;

    await refreshHeader();
    document.getElementById('initBar').style.width = '100%';
    setTimeout(()=>document.getElementById('initOverlay').classList.add('hide'), 400);
  } catch(e) {
    document.getElementById('initMsg').textContent = '錯誤：'+e.message;
  }
}

init();
</script>

