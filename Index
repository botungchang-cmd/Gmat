<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GMAT Practice · DB版</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{--ink:#0d0f14;--paper:#13151c;--card:#1c1f2a;--raised:#222636;--rim:#2c3048;--gold:#c9a84c;--gold2:#e8c96a;--cream:#f0e8d0;--muted:#6b7194;--body:#b8bdd8;--green:#4ade80;--red:#f87171;--blue:#60a5fa;--purple:#a78bfa;--yellow:#fbbf24;--r:12px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--ink);color:var(--body);font-family:'Noto Sans TC',sans-serif;min-height:100vh}
header{background:var(--paper);border-bottom:1px solid var(--rim);padding:0 20px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.logo{font-family:'DM Serif Display',serif;font-size:1.2rem;color:var(--gold2)}
.logo small{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--muted);display:block;letter-spacing:2px;margin-top:-2px}
.hdr-right{display:flex;gap:8px;align-items:center}
.pill{font-family:'DM Mono',monospace;font-size:.67rem;padding:3px 10px;border-radius:20px;background:var(--card);border:1px solid var(--rim);color:var(--muted)}
.pill b{color:var(--cream)}
#timerEl{font-family:'DM Mono',monospace;font-size:.84rem;padding:4px 12px;border-radius:20px;border:1.5px solid var(--rim);color:var(--body);min-width:62px;text-align:center;transition:all .3s;display:none}
#timerEl.warn{border-color:var(--yellow);color:var(--yellow)}
#timerEl.danger{border-color:var(--red);color:var(--red);animation:blink .7s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
main{max-width:800px;margin:0 auto;padding:22px 16px}
.screen{display:none}.screen.active{display:block;animation:rise .3s ease}
@keyframes rise{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* INIT OVERLAY */
#initOverlay{position:fixed;inset:0;background:var(–ink);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .6s}
#initOverlay.hide{opacity:0;pointer-events:none}
.init-logo{font-family:‘DM Serif Display’,serif;font-size:1.8rem;color:var(–gold2);margin-bottom:6px}
.init-sub{font-family:‘DM Mono’,monospace;font-size:.7rem;color:var(–muted);letter-spacing:2px;margin-bottom:24px}
.init-spinner{width:36px;height:36px;border:3px solid var(–rim);border-top-color:var(–gold);border-radius:50%;animation:spin 1s linear infinite;margin-bottom:12px}
@keyframes spin{to{transform:rotate(360deg)}}
.init-msg{font-size:.82rem;color:var(–muted);font-family:‘DM Mono’,monospace}
.init-bar-wrap{width:200px;background:var(–rim);border-radius:4px;height:4px;margin-top:10px;overflow:hidden}
.init-bar{height:100%;background:var(–gold);border-radius:4px;transition:width .3s}

/* HOME */
.hero{text-align:center;padding:30px 0 22px;border-bottom:1px solid var(–rim);margin-bottom:18px;position:relative}
.hero::after{content:’’;position:absolute;bottom:-1px;left:50%;transform:translateX(-50%);width:50px;height:2px;background:var(–gold);border-radius:2px}
.hero h1{font-family:‘DM Serif Display’,serif;font-size:2rem;color:var(–cream);line-height:1.15;margin-bottom:6px}
.hero h1 em{color:var(–gold2);font-style:italic}
.hero p{font-size:.83rem;color:var(–muted)}

.nav-tabs{display:flex;background:var(–card);border:1px solid var(–rim);border-radius:var(–r);padding:4px;margin-bottom:18px}
.nav-tab{flex:1;padding:7px;border-radius:8px;border:none;background:transparent;color:var(–muted);font-family:‘Noto Sans TC’,sans-serif;font-size:.8rem;font-weight:500;cursor:pointer;transition:all .2s}
.nav-tab.active{background:var(–raised);color:var(–cream);border:1px solid var(–rim)}

.sec{font-family:‘DM Mono’,monospace;font-size:.62rem;letter-spacing:2px;text-transform:uppercase;color:var(–muted);margin:16px 0 7px}

/* DB status bar */
.db-status{background:var(–card);border:1px solid var(–rim);border-radius:10px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.db-left{font-size:.78rem;color:var(–muted);line-height:1.6}
.db-left b{color:var(–cream)}
.db-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px}
.db-badge{font-family:‘DM Mono’,monospace;font-size:.6rem;padding:2px 8px;border-radius:20px;background:#4ade8022;color:var(–green);border:1px solid var(–green)}

.stats-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:16px}
.stat-box{background:var(–card);border:1px solid var(–rim);border-radius:var(–r);padding:10px 6px;text-align:center}
.stat-box .sv{font-family:‘DM Mono’,monospace;font-size:1.15rem;font-weight:500;color:var(–cream)}
.stat-box .sl{font-size:.63rem;color:var(–muted);margin-top:1px}

.type-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px}
.type-card{background:var(–card);border:2px solid var(–rim);border-radius:var(–r);padding:13px 8px 10px;cursor:pointer;transition:all .2s;text-align:center}
.type-card:hover{border-color:var(–gold)}.type-card.on{border-color:var(–gold);background:#c9a84c12}
.type-card .ic{font-size:1.4rem;margin-bottom:3px;display:block}
.type-card .nm{font-size:.8rem;font-weight:700;color:var(–cream)}
.type-card .st{font-size:.64rem;color:var(–muted);margin-top:1px}

.filter-row{display:flex;gap:6px}
.filter-btn{flex:1;padding:7px 4px;border:2px solid var(–rim);border-radius:8px;background:var(–card);color:var(–muted);cursor:pointer;font-family:‘Noto Sans TC’,sans-serif;font-size:.78rem;font-weight:500;transition:all .2s}
.filter-btn.on{border-color:var(–gold);background:#c9a84c12;color:var(–cream)}
.filter-btn[data-d=“Easy”].on{border-color:var(–green);background:#4ade8012;color:var(–green)}
.filter-btn[data-d=“Medium”].on{border-color:var(–yellow);background:#fbbf2412;color:var(–yellow)}
.filter-btn[data-d=“Hard”].on{border-color:var(–red);background:#f8717112;color:var(–red)}

.mode-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px}
.mode-btn{padding:14px 10px;border:2px solid var(–rim);border-radius:var(–r);background:var(–card);cursor:pointer;transition:all .2s;text-align:center}
.mode-btn:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(0,0,0,.3)}
.mode-btn .mb-icon{font-size:1.6rem;margin-bottom:5px;display:block}
.mode-btn .mb-title{font-family:‘DM Serif Display’,serif;font-size:.95rem;color:var(–cream);margin-bottom:2px}
.mode-btn .mb-sub{font-size:.7rem;color:var(–muted);line-height:1.4}
.mode-btn .mb-badge{display:inline-block;font-family:‘DM Mono’,monospace;font-size:.56rem;padding:2px 7px;border-radius:20px;margin-bottom:4px;letter-spacing:1px;text-transform:uppercase}
.mode-btn.bank{border-color:var(–gold)}.mode-btn.bank .mb-badge{background:#c9a84c22;color:var(–gold);border:1px solid var(–gold)}
.mode-btn.ai-mode{border-color:var(–blue)}.mode-btn.ai-mode .mb-badge{background:#60a5fa22;color:var(–blue);border:1px solid var(–blue)}

/* Badges */
.badge{font-family:‘DM Mono’,monospace;font-size:.58rem;font-weight:500;padding:2px 7px;border-radius:20px;letter-spacing:.5px;text-transform:uppercase;border:1px solid}
.badge-Q{border-color:var(–blue);color:var(–blue);background:#60a5fa10}
.badge-V{border-color:var(–purple);color:var(–purple);background:#a78bfa10}
.badge-D{border-color:var(–green);color:var(–green);background:#4ade8010}
.badge-Easy{border-color:var(–green);color:var(–green);background:#4ade8010}
.badge-Medium{border-color:var(–yellow);color:var(–yellow);background:#fbbf2410}
.badge-Hard{border-color:var(–red);color:var(–red);background:#f8717110}
.badge-sub{border-color:var(–rim);color:var(–muted)}
.badge-ai{border-color:var(–blue);color:var(–blue);background:#60a5fa15}

/* Question */
.progress-wrap{background:var(–rim);border-radius:4px;height:3px;margin-bottom:16px;overflow:hidden}
.progress-bar{height:100%;background:var(–gold);border-radius:4px;transition:width .5s}
.q-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.q-badges{display:flex;gap:5px;align-items:center;flex-wrap:wrap}
.q-card{background:var(–card);border:1px solid var(–rim);border-radius:var(–r);padding:20px 16px;margin-bottom:10px;border-left:3px solid var(–gold)}
.q-label{font-family:‘DM Mono’,monospace;font-size:.62rem;color:var(–muted);letter-spacing:1px;margin-bottom:8px}
.q-body{font-size:.93rem;line-height:1.8;color:var(–cream)}
.q-body strong{color:var(–gold2)}
.q-data{background:var(–raised);border-radius:7px;padding:10px 12px;margin-top:10px;font-family:‘DM Mono’,monospace;font-size:.78rem;line-height:1.9;color:var(–body);border:1px solid var(–rim);white-space:pre-line}
.options{display:flex;flex-direction:column;gap:7px;margin-bottom:12px}
.opt{background:var(–card);border:2px solid var(–rim);border-radius:9px;padding:10px 12px;cursor:pointer;transition:all .2s;display:flex;align-items:flex-start;gap:9px;font-size:.88rem;line-height:1.6;color:var(–body)}
.opt:hover:not(.locked){border-color:var(–gold);background:#c9a84c08}
.opt.sel{border-color:var(–gold);background:#c9a84c12;color:var(–cream)}
.opt.correct{border-color:var(–green);background:#4ade8012;color:var(–cream)}
.opt.wrong{border-color:var(–red);background:#f8717112}
.opt.locked{cursor:default}
.opt-lbl{font-family:‘DM Mono’,monospace;font-weight:500;min-width:16px;font-size:.78rem;color:var(–muted);padding-top:1px;flex-shrink:0}
.opt.sel .opt-lbl{color:var(–gold)}.opt.correct .opt-lbl{color:var(–green)}.opt.wrong .opt-lbl{color:var(–red)}
.act-row{display:flex;gap:7px}
.btn{padding:9px 15px;border-radius:9px;border:none;font-family:‘Noto Sans TC’,sans-serif;font-size:.84rem;font-weight:500;cursor:pointer;transition:all .2s}
.btn-gold{background:var(–gold);color:var(–ink);flex:1}.btn-gold:hover{background:var(–gold2)}
.btn-gold:disabled{opacity:.3;cursor:not-allowed}
.btn-ghost{background:var(–card);color:var(–body);border:1px solid var(–rim)}.btn-ghost:hover{border-color:var(–muted)}
.exp-box{background:var(–paper);border:1px solid var(–rim);border-left:3px solid var(–blue);border-radius:var(–r);padding:15px 16px;margin-top:10px;display:none}
.exp-box.show{display:block;animation:rise .3s ease}
.result-banner{display:flex;align-items:center;gap:7px;padding:8px 10px;border-radius:7px;margin-bottom:9px;font-size:.84rem;font-weight:600}
.result-banner.ok{background:#4ade8015;color:var(–green);border:1px solid #4ade8030}
.result-banner.no{background:#f8717115;color:var(–red);border:1px solid #f8717130}
.exp-label{font-family:‘DM Mono’,monospace;font-size:.58rem;letter-spacing:2px;text-transform:uppercase;color:var(–blue);margin-bottom:5px}
.exp-text{font-size:.86rem;line-height:1.8;color:var(–body)}
.exp-text strong{color:var(–gold2)}

/* AI */
.ai-loading{text-align:center;padding:60px 20px}
.ai-spinner{width:42px;height:42px;border:3px solid var(–rim);border-top-color:var(–blue);border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 14px}
.ai-loading strong{color:var(–blue);display:block;font-size:.92rem;margin-bottom:4px}
.ai-loading p{color:var(–muted);font-size:.84rem}

.api-setup{background:var(–card);border:1px solid var(–blue);border-radius:var(–r);padding:16px;margin-bottom:12px}
.api-setup h3{color:var(–blue);font-size:.88rem;margin-bottom:5px}
.api-setup p{font-size:.78rem;color:var(–muted);margin-bottom:9px;line-height:1.6}
.api-input{width:100%;padding:8px 10px;background:var(–raised);border:1px solid var(–rim);border-radius:7px;color:var(–cream);font-family:‘DM Mono’,monospace;font-size:.78rem;outline:none;transition:border-color .2s}
.api-input:focus{border-color:var(–blue)}
.api-hint{font-size:.68rem;color:var(–muted);margin-top:5px}
.api-hint a{color:var(–blue)}

/* Results */
.score-hero{background:var(–card);border:1px solid var(–rim);border-radius:var(–r);padding:26px 18px;text-align:center;margin-bottom:16px;position:relative;overflow:hidden}
.score-hero::before{content:’’;position:absolute;top:-40px;right:-40px;width:150px;height:150px;border-radius:50%;background:radial-gradient(circle,#c9a84c12,transparent 70%)}
.score-ring{width:100px;height:100px;border-radius:50%;border:4px solid var(–gold);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 12px}
.score-pct{font-family:‘DM Serif Display’,serif;font-size:1.8rem;color:var(–gold2)}
.score-lbl{font-size:.6rem;color:var(–muted);letter-spacing:1px}
.score-msg{font-family:‘DM Serif Display’,serif;font-size:1.2rem;color:var(–cream);margin-bottom:2px}
.score-sub{font-size:.8rem;color:var(–muted)}
.result-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-top:16px}
.r-cell{background:var(–raised);border-radius:8px;padding:10px;text-align:center}
.r-val{font-family:‘DM Mono’,monospace;font-size:1.15rem;font-weight:500}
.r-lbl{font-size:.63rem;color:var(–muted);margin-top:2px}
.review-item{background:var(–card);border:1px solid var(–rim);border-radius:var(–r);padding:11px 12px;margin-bottom:6px}
.ri-ok{border-left:3px solid var(–green)}.ri-no{border-left:3px solid var(–red)}
.ri-meta{font-family:‘DM Mono’,monospace;font-size:.63rem;color:var(–muted);margin-bottom:3px}
.ri-text{font-size:.82rem;color:var(–body);line-height:1.5}
.ri-bottom{display:flex;gap:4px;margin-top:5px;align-items:center;flex-wrap:wrap}

/* Wrong log */
.wl-item{background:var(–card);border:1px solid var(–rim);border-left:3px solid var(–red);border-radius:var(–r);padding:11px;margin-bottom:6px}
.wl-actions{display:flex;gap:7px;margin-bottom:10px;flex-wrap:wrap}
.wl-btn{background:transparent;border:1px solid var(–rim);color:var(–muted);border-radius:7px;padding:6px 11px;cursor:pointer;font-size:.76rem;transition:all .2s;font-family:‘Noto Sans TC’,sans-serif}
.wl-btn:hover{border-color:var(–muted);color:var(–cream)}
.wl-btn.red{border-color:var(–red);color:var(–red)}.wl-btn.red:hover{background:#f8717112}

.empty{text-align:center;padding:46px 20px;color:var(–muted)}
.empty .ei{font-size:1.8rem;margin-bottom:8px}
.start-btn{width:100%;margin-top:16px;padding:13px;background:var(–gold);border:none;border-radius:var(–r);color:var(–ink);font-family:‘DM Serif Display’,serif;font-size:.95rem;cursor:pointer;transition:all .25s}
.start-btn:hover{background:var(–gold2);transform:translateY(-1px)}
.start-btn.blue{background:var(–blue);color:#fff}.start-btn.blue:hover{background:#4d9ef5}
.start-btn.ghost{background:var(–card);color:var(–body);border:1px solid var(–rim)}.start-btn.ghost:hover{border-color:var(–muted)}

@media(max-width:560px){.type-grid{grid-template-columns:1fr 1fr}.stats-bar{grid-template-columns:1fr 1fr}.result-grid{grid-template-columns:1fr 1fr}main{padding:14px 12px}.hero h1{font-size:1.7rem}.mode-row{grid-template-columns:1fr}}
</style>

</head>
