function showAISetup() { showScreen('aiSetupScreen'); }

async function startAIQuiz() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key) { alert('請輸入 Anthropic API Key'); return; }
  await setSetting('apiKey', key);
  S.mode = 'ai';
  S.quiz = []; S.cur = 0; S.answers = []; S.sel = null; S.elapsed = 0; S.submitted = false;
  showScreen('aiLoadScreen');
  startTimer();
  await fetchAIQuestion(key);
}

async function fetchAIQuestion(key) {
  showScreen('aiLoadScreen');
  const savedKey = key || await getSetting('apiKey');
  const typeMap = {
    all:'any GMAT type (Quantitative PS, Data Sufficiency, Verbal CR, Sentence Correction, or Data Insights)',
    Q:'Quantitative (Problem Solving or Data Sufficiency)',
    V:'Verbal (Critical Reasoning or Sentence Correction)',
    D:'Data Insights (Data Sufficiency or Data Interpretation)'
  };
  const diffs = [...S.diffs];
  const diff = diffs[Math.floor(Math.random()*diffs.length)];
  const prompt = `Generate one original GMAT-style ${diff} difficulty ${typeMap[S.aiType]} question.

Return ONLY a valid JSON object (no markdown fences, no explanation outside JSON):
{
  "type": "Q" or "V" or "D",
  "subtype": "Problem Solving" or "Data Sufficiency" or "Critical Reasoning" or "Sentence Correction" or "Data Interpretation",
  "difficulty": "${diff}",
  "question": "Question text in English (use <strong> for key terms)",
  "options": ["A","B","C","D","E"],
  "answer": 0,
  "explanation": "中文詳解：逐步解析正確答案，說明為何其他選項不對",
  "data": null
}

answer is the 0-based index of the correct option.
For Data Sufficiency, always use these exact 5 options: ["Statement (1) ALONE is sufficient","Statement (2) ALONE is sufficient","BOTH statements together are sufficient","EACH statement ALONE is sufficient","NEITHER statement is sufficient"]`;

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': savedKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1200,
        messages: [{ role: 'user', content: prompt }]
      })
    });
    const data = await resp.json();
    if (!resp.ok) throw new Error(data.error?.message || 'API error');
    const text = data.content.map(c=>c.text||'').join('').trim().replace(/```json|```/g,'').trim();
    const q = JSON.parse(text);
    const aiQ = {
      id: 'AI'+Date.now().toString(36),
      type: q.type || 'Q',
      difficulty: q.difficulty || diff,
      subtype: q.subtype || 'Problem Solving',
      question: q.question,
      options: q.options,
      answer: q.answer,
      explanation: q.explanation,
      data: q.data || null,
      source: 'ai',
      createdAt: Date.now()
    };
    // Save AI question to DB
    await txPut('questions', aiQ);
    await refreshHeader();
    S.quiz.push(aiQ);
    S.cur = S.quiz.length - 1;
    S.sel = null; S.submitted = false;
    showScreen('qScreen');
    renderQ();
  } catch(e) {
    alert('AI 出題失敗：' + e.message + '\n改用題庫模式。');
    await startBankQuiz();
  }
}

/* ════════════════════════════════════════════════
   QUESTION RENDER
════════════════════════════════════════════════ */
function renderQ() {
  const q = S.quiz[S.cur];
  S.sel = null; S.submitted = false;
  const tN = {Q:'Quantitative',V:'Verbal',D:'Data Insights'};
  const n = S.mode==='bank' ? S.quiz.length : '∞';
  document.getElementById('qCounter').textContent = `${S.cur+1} / ${n}`;
  document.getElementById('progBar').style.width = S.mode==='bank' ? `${(S.cur/S.quiz.length)*100}%` : '100%';
  document.getElementById('qLabel').textContent = `Q${S.cur+1} · ${q.subtype}`;
  document.getElementById('qBadges').innerHTML =
    `<span class="badge badge-${q.type}">${tN[q.type]||q.type}</span>
     <span class="badge badge-${q.difficulty}">${q.difficulty}</span>
     <span class="badge badge-sub">${q.subtype}</span>`+
    (q.source==='ai'?'<span class="badge badge-ai">🤖 AI</span>':'');
  document.getElementById('qBody').innerHTML = q.question;
  const dEl = document.getElementById('qData');
  if (q.data) { dEl.style.display=''; dEl.textContent=q.data; } else dEl.style.display='none';
  document.getElementById('opts').innerHTML = q.options.map((o,i)=>
    `<div class="opt" onclick="pickOpt(this,${i})">
       <span class="opt-lbl">${L(i)}</span><span>${o}</span>
     </div>`).join('');
  document.getElementById('expBox').classList.remove('show');
  document.getElementById('btnSub').style.display = '';
  document.getElementById('btnNext').style.display = 'none';
  document.getElementById('btnSub').disabled = true;
  document.getElementById('resBanner').style.display = '';
  if (S.mode==='ai') document.getElementById('btnNext').textContent = '🤖 AI 出下一題 →';
  else document.getElementById('btnNext').textContent = '下一題 →';
}

function pickOpt(el, i) {
  if (S.submitted) return;
  document.querySelectorAll('.opt').forEach(o=>o.classList.remove('sel'));
  el.classList.add('sel'); S.sel = i;
  document.getElementById('btnSub').disabled = false;
}

async function submitAns() {
  if (S.sel === null) return;
  S.submitted = true;
  const q = S.quiz[S.cur];
  const isOk = S.sel === q.answer;
  S.answers.push({ q, chosen: S.sel, ok: isOk });

  // Save to history DB
  await txPut('history', {
    qid: q.id, type: q.type, difficulty: q.difficulty,
    subtype: q.subtype, correct: isOk,
    chosen: S.sel, answer: q.answer,
    timestamp: Date.now(), source: q.source||'bank'
  });

  // Save to wrong log if wrong
  if (!isOk) {
    await txPut('wronglog', {
      qid: q.id, ...q,
      wrongAt: Date.now()
    });
  }
  await refreshHeader();

  document.querySelectorAll('.opt').forEach((el,i) => {
    el.classList.add('locked');
    if (i===q.answer) el.classList.add('correct');
    else if (i===S.sel && !isOk) el.classList.add('wrong');
  });
  revealExp(isOk);
  document.getElementById('btnSub').style.display = 'none';
  document.getElementById('btnNext').style.display = '';
}

function revealExp(ok) {
  const box = document.getElementById('expBox');
  const b   = document.getElementById('resBanner');
  const q   = S.quiz[S.cur];
  if (ok===true)  { b.className='result-banner ok'; b.innerHTML='✅ 答對了！Correct!'; }
  else if (ok===false) { b.className='result-banner no'; b.innerHTML=`❌ 答錯了。正確答案：<strong>${L(q.answer)}</strong>`; }
  else b.style.display = 'none';
  document.getElementById('expText').innerHTML = q.explanation;
  box.classList.add('show');
}

async function nextQ() {
  if (S.mode === 'ai') {
    const savedKey = await getSetting('apiKey');
    await fetchAIQuestion(savedKey);
  } else {
    S.cur++;
    if (S.cur >= S.quiz.length) endQuiz();
    else renderQ();
  }
}

