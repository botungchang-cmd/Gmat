async function generateAndStore(progressCb) {
  const existing = await txCount('questions');
  if (existing >= 100) return existing; // already seeded

  const targets = {
    'Q-Easy': 80, 'Q-Medium': 80, 'Q-Hard': 60,
    'V-Easy': 60, 'V-Medium': 60, 'V-Hard': 40,
    'D-Easy': 50, 'D-Medium': 50, 'D-Hard': 40,
  };
  const counters = {};
  Object.keys(targets).forEach(k => counters[k] = 0);
  const total = Object.values(targets).reduce((a,b)=>a+b,0);
  const questions = [];
  let attempts = 0, generated = 0;

  while (generated < total && attempts < total * 8) {
    attempts++;
    const gen = GENERATORS[attempts % GENERATORS.length];
    const key = `${gen.type}-${gen.difficulty}`;
    if (!targets[key] || counters[key] >= targets[key]) continue;
    try {
      const q = gen.gen();
      if (!q || !q.o || q.o.length < 2 || q.a < 0 || q.a >= q.o.length) continue;
      questions.push({
        id: uid(),
        type: gen.type,
        difficulty: gen.difficulty,
        subtype: gen.sub,
        question: q.q,
        options: q.o,
        answer: q.a,
        explanation: q.ex,
        data: q.data || null,
        source: 'bank',
        createdAt: Date.now()
      });
      counters[key]++;
      generated++;
      if (progressCb && generated % 20 === 0) progressCb(generated, total);
    } catch(e) {}
  }

  // Bulk insert
  await txPutBulk('questions', questions);
  if (progressCb) progressCb(total, total);
  return generated;
}

